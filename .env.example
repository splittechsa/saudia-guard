# Supabase Configuration (External Instance)
# IMPORTANT: These variables MUST be set in Vercel Dashboard for production deployment
# Do NOT commit real keys to version control

# Public client-side variables (VITE_ prefix makes them accessible in browser)
VITE_SUPABASE_URL="https://your-supabase-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
# If your deploy environment uses the Supabase anonymous key name, this alias is supported too:
# VITE_SUPABASE_ANON_KEY="your-supabase-publishable-key"
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"

# Server-side variables (these are used by Supabase CLI and functions)
SUPABASE_URL="https://your-supabase-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"

# Supabase CLI requires these for migrations and function deployment
SUPABASE_ACCESS_TOKEN="your-supabase-access-token"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
